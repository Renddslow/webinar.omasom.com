<!doctype html>
<html lang="en">
    <head>
        <title><%= metaTitle %> Webinar | Omaha School of Ministry Webinars</title>
        <meta name="robots" content="noindex, nofollow">
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <style>
            * {
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell,
                "Open Sans", "Helvetica Neue", sans-serif;
                padding: 0;
                margin: 0;
                box-sizing: border-box;
            }

            html, body {
                height: 100%;
            }

            body {
                background: #f8f9fb;
                display: grid;
                grid-template-columns: minmax(0, 200px) minmax(0, 1fr);
            }

            form {

            }

            .card {
                padding: 0 18px;
                border: 1px solid #e2e5e9;
                background: #fff;
                border-radius: 8px;
            }

            .row {
                padding: 24px 0;
            }

            .row:not(:last-child) {
                border-bottom: 1px solid #E5E7EC;
            }

            section {
                width: 100%;
                max-width: 650px;
                margin: 0 auto;
            }

            section h1 {
                margin: 48px 0 24px;
            }

            footer {
                width: 100%;
                padding: 24px 0;
                position: relative;
                display: block;
            }

            footer button {
                padding: 12px 24px;
                appearance: none;
                border-radius: 4px;
                background: #113c7c;
                font-size: 16px;
                color: #fff;
                font-weight: 600;
                border: 0;
                margin-left: auto;
                display: block;
            }
        </style>
    </head>
    <body>
        <%- header %>
        <section>
            <h1><%= metaTitle %> Webinar</h1>
            <form action="/admin/webinars/<%= updateId %>" method="post">
                <div class="card">
                    <div class="row">
                        <admin-form-input
                                label="Title"
                                value="<%= values.title %>"
                                helptext="The title of the session which will be presented on the landing page."
                        ></admin-form-input>
                    </div>
                    <div class="row">
                        <admin-form-input
                                label="Description"
                                type="textarea"
                                value="<%= values.description %>"
                                helptext="A strong description of the session which will be presented on the landing page and social media."
                        ></admin-form-input>
                    </div>
                    <div class="row">
                        <admin-form-input
                                label="Meeting Link"
                                value="<%= values.meeting_link %>"
                                helptext="A Zoom or Google Meet link that will host the webinar."
                        ></admin-form-input>
                    </div>
                    <div class="row">
                        <admin-form-input
                                label="Start Time"
                                value="<%= values.starts_at %>"
                                helptext="The start date and time of the event."
                        ></admin-form-input>
                    </div>
                </div>
                <% if (updateId !== 'new') { %>
                    <h2>Handouts</h2>
                <% } %>
                <footer>
                    <button type="submit">Save</button>
                </footer>
            </form>
        </section>
    </body>
    <script src="/admin-inputs.js"></script>
</html>