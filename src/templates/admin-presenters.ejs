<!doctype html>
<html lang="en">
    <head>
        <title>Manage Presenters | Omaha School of Ministry Webinars</title>
        <meta name="robots" content="noindex, nofollow">
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <script src="https://unpkg.com/imagekit-javascript/dist/imagekit.min.js"></script>
        <link rel="stylesheet" href="/admin.css">
        <script>
            const css = (s) => {
                const sheet = new CSSStyleSheet();
                s.map((rule) => rule.split("\n\n"))
                    .flat()
                    .forEach((rule) => sheet.insertRule(rule));
                return sheet;
            };
        </script>
    </head>
    <body>
    <%- header %>
    <section>
        <h1>Manage Presenters</h1>
        <div class="card">
            <table>
                <% for (const presenter of presenters.sort((a, b) => a.name.localeCompare(b.name))) { %>
                    <tr>
                        <td style="width: 200px"><a href="/admin/presenters/<%= presenter.id %>"><%= presenter.name %></a></td>
                        <td><%= presenter.title %></td>
                        <td><%= presenter.org %></td>
                    </tr>
                <% } %>
            </table>
        </div>
    </section>
    </body>
</html>